# ===========================================
# Google AI (Gemini)
# Get your API key from: https://aistudio.google.com/app/apikey
# ===========================================
GOOGLE_API_KEY=your_google_api_key_here

# ===========================================
# Firebase Configuration
# ===========================================
# For Cloud Run: Uses Application Default Credentials (ADC)
# No additional config needed - handled automatically by GOOGLE_APPLICATION_CREDENTIALS

# For local development: Point to your service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Or set the service account JSON content directly (not recommended for production)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# ===========================================
# Application
# ===========================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
